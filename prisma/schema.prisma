generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String   @unique
  password    String
  name        String?
  phone       String?  // Added for personal contact info
  role        Role     @default(STUDENT)

  
  // Many-to-Many with Institute (Admins can manage multiple)
  institutes    Institute[] @relation(fields: [instituteIds], references: [id])
  instituteIds  String[]    @db.ObjectId
  
  // Single active/default institute for dashboard
  defaultInstituteId String? @db.ObjectId
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Dynamic fields storage
  metadata    Json?

  teacherProfiles TeacherProfile[]
}

model Institute {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  type        String?  // e.g., "Madrasa", "Kindergarten"
  address     String?
  phone       String?
  email       String?
  website     String?
  logo        String?
  coverImage  String?  // Added for dashboard cover
  
  // Form Configuration
  studentFormConfig Json?

  // Many-to-Many with User
  admins      User[]   @relation(fields: [adminIds], references: [id])
  adminIds    String[] @db.ObjectId
  
  teacherProfiles TeacherProfile[]

  // Relations
  classes     Class[]
  books       Book[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Class {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  order       Int      @default(0)
  
  institute   Institute @relation(fields: [instituteId], references: [id])
  instituteId String    @db.ObjectId
  
  groups      Group[]
  books       Book[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Group {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  order       Int      @default(0)
  
  class       Class    @relation(fields: [classId], references: [id])
  classId     String   @db.ObjectId
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


enum Role {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  TEACHER
  GUARDIAN
  STUDENT
  DEMO
}


model SiteSettings {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  appName        String   @default("Edusy")
  logo           String?
  coverImage     String?
  introduction   String?
  supportEmail   String?
  supportPhone   String?
  
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model TeacherProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  
  instituteId String   @db.ObjectId
  institute   Institute @relation(fields: [instituteId], references: [id])
  
  designation String?
  department  String?
  joinDate    DateTime @default(now())
  
  // Permissions: { canCollectFees: boolean, canManageResult: boolean, canTakeAttendance: boolean, ... }
  permissions Json?    
  
  // Class Restrictions: List of Class IDs this teacher acts upon
  assignedClassIds String[] @db.ObjectId
  
  isAdmin     Boolean  @default(false)
  status      String   @default("PENDING") // PENDING, ACTIVE, REJECTED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, instituteId])
}

model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  type        String   // "TEACHER_LEFT", "TEACHER_REMOVED", etc.
  title       String
  message     String
  read        Boolean  @default(false)
  metadata    Json?    // Store additional info like teacher name, institute name, instituteId
  createdAt   DateTime @default(now())
}

model Book {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  
  class       Class    @relation(fields: [classId], references: [id])
  classId     String   @db.ObjectId
  
  institute   Institute @relation(fields: [instituteId], references: [id])
  instituteId String    @db.ObjectId
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
