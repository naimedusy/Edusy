generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String?  @unique
  password    String
  name        String?
  phone       String?  @unique // Added for personal contact info and unique login
  role        Role     @default(STUDENT)

  
  // Many-to-Many with Institute (Admins can manage multiple)
  institutes    Institute[] @relation(fields: [instituteIds], references: [id])
  instituteIds  String[]    @db.ObjectId
  
  // Single active/default institute for dashboard
  defaultInstituteId String? @db.ObjectId
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Dynamic fields storage
  metadata    Json?

  teacherProfiles TeacherProfile[]
  assignments     Assignment[] @relation("TeacherAssignments")
  submissions     Submission[] @relation("StudentSubmissions")
}

model Institute {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  type        String?  // e.g., "Madrasa", "Kindergarten"
  address     String?
  phone       String?
  email       String?
  website     String?
  logo        String?
  coverImage  String?  // Added for dashboard cover
  
  // Form Configuration
  studentFormConfig Json?

  // Many-to-Many with User
  admins      User[]   @relation(fields: [adminIds], references: [id])
  adminIds    String[] @db.ObjectId
  
  teacherProfiles TeacherProfile[]

  // Relations
  classes     Class[]
  books       Book[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments Assignment[]
}

model Class {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  order       Int      @default(0)
  
  institute   Institute @relation(fields: [instituteId], references: [id])
  instituteId String    @db.ObjectId
  
  groups      Group[]
  books       Book[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments Assignment[]
}

model Group {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  order       Int      @default(0)
  
  class       Class    @relation(fields: [classId], references: [id])
  classId     String   @db.ObjectId
  
  books       Book[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments Assignment[]
}


enum Role {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  TEACHER
  GUARDIAN
  STUDENT
  DEMO
}


model SiteSettings {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  appName        String   @default("Edusy")
  logo           String?
  coverImage     String?
  introduction   String?
  supportEmail   String?
  supportPhone   String?
  
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model TeacherProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  
  instituteId String   @db.ObjectId
  institute   Institute @relation(fields: [instituteId], references: [id])
  
  designation String?
  department  String?
  joinDate    DateTime @default(now())
  
  // Permissions: { canCollectFees: boolean, canManageResult: boolean, canTakeAttendance: boolean, ... }
  permissions Json?    
  
  // Class Restrictions: List of Class IDs this teacher acts upon
  assignedClassIds String[] @db.ObjectId
  
  isAdmin     Boolean  @default(false)
  status      String   @default("PENDING") // PENDING, ACTIVE, REJECTED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, instituteId])
}

model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  type        String   // "TEACHER_LEFT", "TEACHER_REMOVED", etc.
  title       String
  message     String
  read        Boolean  @default(false)
  metadata    Json?    // Store additional info like teacher name, institute name, instituteId
  createdAt   DateTime @default(now())
}

model Book {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  nameBangla  String?  // Multilingual name
  nameEnglish String?  // Multilingual name
  nameArabic  String?  // Multilingual name
  description String?  // Book description
  coverImage  String?  // Added for book cover
  author      String?  // Added for book subtitle/author
  rating      Float?   @default(4.0) // Added for book rating
  pdfUrl      String?  // Link to uploaded PDF
  readLink    String?  // Link to external reading site
  
  category    String?  // Added for book categorization (e.g., "Fiction", "Science")
  
  class       Class?   @relation(fields: [classId], references: [id])
  classId     String?  @db.ObjectId
  
  group       Group?   @relation(fields: [groupId], references: [id])
  groupId     String?  @db.ObjectId
  
  institute   Institute? @relation(fields: [instituteId], references: [id])
  instituteId String?    @db.ObjectId
  
  // Grading Settings
  totalMarks   Int?      @default(100)
  gradingRules Json?     // Array of GradingRule objects
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments Assignment[]
}

model Assignment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  type        AssignmentType @default(HOMEWORK)
  status      AssignmentStatus @default(PUBLISHED)
  deadline    DateTime?
  
  // Relations
  institute   Institute @relation(fields: [instituteId], references: [id])
  instituteId String    @db.ObjectId
  
  teacher     User      @relation("TeacherAssignments", fields: [teacherId], references: [id])
  teacherId   String    @db.ObjectId
  
  class       Class?    @relation(fields: [classId], references: [id])
  classId     String?   @db.ObjectId
  
  group       Group?    @relation(fields: [groupId], references: [id])
  groupId     String?   @db.ObjectId
  
  book        Book?     @relation(fields: [bookId], references: [id])
  bookId      String?   @db.ObjectId
  
  submissions Submission[]
  
  // Resource references (PDFs, Notes, Suggestions)
  resources   Json?     // Array of { name: string, url: string, type: string }
  
  createdAt   DateTime @default(now())
  scheduledDate DateTime @default(now())
  releaseAt   DateTime?
  updatedAt   DateTime @updatedAt
}

model Submission {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  assignment    Assignment @relation(fields: [assignmentId], references: [id])
  assignmentId  String     @db.ObjectId
  
  student       User       @relation("StudentSubmissions", fields: [studentId], references: [id])
  studentId     String     @db.ObjectId
  
  content       String?    // Text answer
  attachments   Json?      // Array of { name: string, url: string, type: string }
  
  // New: Track progress for individual tasks within structured assignments
  // Format: { [taskId]: { status: 'DONE' | 'PENDING', attachments: [], submittedAt: Date, feedback: string } }
  taskProgress  Json?      

  status        SubmissionStatus @default(SUBMITTED)
  grade         String?
  feedback      String?
  
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([assignmentId, studentId])
}

enum AssignmentType {
  HOMEWORK
  CLASSWORK
  REVISION
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  RELEASED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  APPROVED
  RETRY
  REJECTED
}
