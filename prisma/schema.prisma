generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String   @unique
  password    String
  name        String?
  phone       String?  // Added for personal contact info
  role        Role     @default(STUDENT)

  
  // Many-to-Many with Institute (Admins can manage multiple)
  institutes    Institute[] @relation(fields: [instituteIds], references: [id])
  instituteIds  String[]    @db.ObjectId
  
  // Single active/default institute for dashboard
  defaultInstituteId String? @db.ObjectId
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Dynamic fields storage
  metadata    Json?
}

model Institute {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  type        String?  // e.g., "Madrasa", "Kindergarten"
  address     String?
  phone       String?
  email       String?
  website     String?
  logo        String?
  coverImage  String?  // Added for dashboard cover
  
  // Form Configuration
  studentFormConfig Json?

  // Many-to-Many with User
  admins      User[]   @relation(fields: [adminIds], references: [id])
  adminIds    String[] @db.ObjectId

  // Relations
  classes     Class[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Class {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  order       Int      @default(0)
  
  institute   Institute @relation(fields: [instituteId], references: [id])
  instituteId String    @db.ObjectId
  
  groups      Group[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Group {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  order       Int      @default(0)
  
  class       Class    @relation(fields: [classId], references: [id])
  classId     String   @db.ObjectId
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


enum Role {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  TEACHER
  GUARDIAN
  STUDENT
  DEMO
}


model SiteSettings {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  appName        String   @default("Edusy")
  logo           String?
  coverImage     String?
  introduction   String?
  supportEmail   String?
  supportPhone   String?
  
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}
